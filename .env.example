# Epic FHIR sandbox (from open.epic.com)
EPIC_CLIENT_ID=your-epic-non-production-client-id
EPIC_AUTH_URL=https://fhir.epic.com/interactive-fhir-oauth/oauth2/authorize
EPIC_TOKEN_URL=https://fhir.epic.com/interactive-fhir-oauth/oauth2/token
EPIC_FHIR_BASE=https://fhir.epic.com/interactive-fhir/r4/

# Redirect URI must match exactly what is registered in your Epic app.
# Local:   http://localhost:3000/api/auth/callback
# Vercel:  https://your-app.vercel.app/api/auth/callback
EPIC_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Session encryption (use a long random string, e.g. openssl rand -base64 32)
SESSION_SECRET=your-session-secret-at-least-32-chars
